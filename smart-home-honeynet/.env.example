# Copy to .env and adjust for your lab. All values have safe defaults.

# --- Honeypot bind addresses/ports ---
# Bind to 0.0.0.0 ONLY inside an isolated lab network segment.
HONEYNET_TELNET_HOST=127.0.0.1
HONEYNET_TELNET_PORT=2323
HONEYNET_HTTP_HOST=127.0.0.1
HONEYNET_HTTP_PORT=8080

# --- Storage ---
HONEYNET_DB=honeynet.db
HONEYNET_EVENTS_JSONL=logs/events.jsonl
HONEYNET_ALERTS_JSONL=logs/alerts.jsonl
HONEYNET_RULES=config/detection_rules.yaml

# --- ELK (docker-compose) ---
ELASTIC_HOSTS=http://elasticsearch:9200
# ELASTIC_USER=elastic
# ELASTIC_PASSWORD=changeme
